# PostgreSQL connection (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/primetrade

# JWT settings
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# Any user who registers with this email is automatically made an admin
ADMIN_EMAIL=admin@example.com

# Optional - only used if Redis caching is enabled
REDIS_URL=redis://localhost:6379/0
